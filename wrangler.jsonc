{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "thasmo-website",
	"compatibility_date": "2026-06-04",
	"preview_urls": true,
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "./dist/"
	},
	"routes": [
		{
			"pattern": "thasmo.com",
			"custom_domain": true
		},
		{
			"pattern": "www.thasmo.com",
			"custom_domain": true
		}
	]
}
